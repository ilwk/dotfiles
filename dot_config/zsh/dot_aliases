# Aliases

# Git
alias g=git

# ls
alias ll='ls -lh'
alias la='ls -lAh'

# tar
alias tarls='tar -tvf'
alias untar='tar -xf'

# find
alias fd='find . -type d -name'
alias ff='find . -type f -name'

# misc
alias _=sudo
alias please=sudo
alias zshrc='${EDITOR:-vim} "${ZDOTDIR:-$HOME}"/.zshrc'
alias zdot='cd ${ZDOTDIR:-~}'
alias anti=antidote